# FRED（セントルイス連銀）API キー
# 取得先: https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=your_fred_api_key_here

# EIA（米国エネルギー情報局）API キー
# 取得先: https://www.eia.gov/opendata/register.php
EIA_API_KEY=your_eia_api_key_here

# e-Stat（政府統計ポータル）API キー
# 取得先: https://api.e-stat.go.jp/
ESTAT_API_KEY=your_estat_api_key_here
